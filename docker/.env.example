# ─── Blender MCP Server Configuration ─────────────────────────────
#
# Copy this file to .env and fill in your values.

# Where the Blender addon's command socket is listening. This is the host
# running Blender itself (e.g. UR1), NOT this container.
BLENDER_HOST=192.168.1.33
BLENDER_PORT=9876

# Host port this container's MCP endpoint is published on (bound to
# 127.0.0.1 only — see docker-compose.example.yml).
MCP_PUBLISH_PORT=8877

TZ=UTC
